<Window x:Class="ScreenTranslator.Views.AddOcrLanguageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add OCR language"
        Width="520"
        Height="520"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF1E1E1E">
    <Window.Resources>
        <Style x:Key="Label" TargetType="TextBlock">
            <Setter Property="Foreground" Value="White" />
            <Setter Property="Margin" Value="0,6,0,2" />
        </Style>
    </Window.Resources>

    <DockPanel Margin="14" LastChildFill="True">

        <TextBlock DockPanel.Dock="Top"
                   Style="{StaticResource Label}"
                   TextWrapping="Wrap"
                   Text="Pick a language and click Install. Windows will prompt for administrator permission and install only the OCR engine data — no keyboard layout or display language will be changed. No reboot required." />

        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="RefreshButton"
                    Content="Refresh"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="RefreshButton_OnClick" />
            <Button x:Name="InstallButton"
                    Content="Install selected"
                    Padding="12,4"
                    Margin="0,0,8,0"
                    Click="InstallButton_OnClick"
                    IsEnabled="False" />
            <Button Content="Close"
                    Padding="12,4"
                    IsCancel="True" />
        </StackPanel>

        <TextBlock x:Name="StatusText"
                   DockPanel.Dock="Bottom"
                   Style="{StaticResource Label}"
                   TextWrapping="Wrap"
                   Foreground="#FFAAAAAA" />

        <TextBlock x:Name="DetectedTagsText"
                   DockPanel.Dock="Bottom"
                   Style="{StaticResource Label}"
                   TextWrapping="Wrap"
                   FontFamily="Consolas"
                   FontSize="11"
                   Foreground="#FF888888" />

        <ListBox x:Name="LanguagesList"
                 Margin="0,8,0,0"
                 Background="#FF2A2A2A"
                 Foreground="White"
                 BorderBrush="#FF3A3A3A"
                 SelectionChanged="LanguagesList_OnSelectionChanged">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <Grid Margin="4,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="{Binding DisplayName}" FontWeight="Bold" Foreground="White" />
                            <TextBlock Text="{Binding Tag}" Foreground="#FFAAAAAA" FontFamily="Consolas" FontSize="11" />
                        </StackPanel>
                        <TextBlock Grid.Column="1"
                                   VerticalAlignment="Center"
                                   FontWeight="Bold"
                                   Text="{Binding StatusText}"
                                   Foreground="{Binding StatusBrush}" />
                    </Grid>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
    </DockPanel>
</Window>
