<Window x:Class="ScreenTranslator.Views.OverlayWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ScreenTranslator Overlay"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        Topmost="True"
        ShowInTaskbar="False"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition x:Name="CaptureRow" Height="160" />
            <RowDefinition Height="*" MinHeight="40" />
        </Grid.RowDefinitions>

        <!-- Capture region: visual marker only. BitBlt captures the desktop, not this window. -->
        <Border x:Name="CaptureBorder"
                Grid.Row="0"
                BorderBrush="#FFE25C5C"
                BorderThickness="2"
                Background="#01000000"
                MouseLeftButtonDown="CaptureArea_OnMouseLeftButtonDown" />

        <!-- Bottom-right resize handle for the capture region (edit mode only) -->
        <Thumb x:Name="ResizeThumb"
               Grid.Row="0"
               HorizontalAlignment="Right"
               VerticalAlignment="Bottom"
               Width="14"
               Height="14"
               Cursor="SizeNWSE"
               DragDelta="ResizeThumb_OnDragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="#FFE25C5C" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- Splitter between capture and translation panel (edit mode only) -->
        <Thumb x:Name="SplitterThumb"
               Grid.Row="0"
               HorizontalAlignment="Stretch"
               VerticalAlignment="Bottom"
               Height="4"
               Cursor="SizeNS"
               DragDelta="SplitterThumb_OnDragDelta">
            <Thumb.Template>
                <ControlTemplate TargetType="Thumb">
                    <Rectangle Fill="#80E25C5C" />
                </ControlTemplate>
            </Thumb.Template>
        </Thumb>

        <!-- Translation panel -->
        <Border Grid.Row="1"
                Background="#CC101010"
                BorderBrush="#FF3A3A3A"
                BorderThickness="1"
                Padding="8">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <TextBlock x:Name="TranslatedTextBlock"
                           Text="{Binding TranslatedText}"
                           Foreground="White"
                           FontSize="16"
                           TextWrapping="Wrap" />
            </ScrollViewer>
        </Border>
    </Grid>
</Window>
